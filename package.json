{
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "_cleanup": "pkill -9 -x solana-test-val 2>/dev/null; docker ps -q --filter 'name=artifacts-' | xargs -r docker rm -f 2>/dev/null; true",
    "pretest": "yarn _cleanup",
    "test": "arcium test",
    "posttest": "yarn _cleanup",
    "test:clean": "arcium clean --only-accounts && arcium test",
    "test:nuke": "rm -rf .anchor/test-ledger artifacts && arcium test"
  },
  "dependencies": {
    "@arcium-hq/client": "0.9.2",
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^5.7.3",
    "prettier": "^2.6.2"
  }
}
