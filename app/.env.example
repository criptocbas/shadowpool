# ShadowPool frontend environment variables — copy to `.env.local` for
# local dev; set these in the Vercel dashboard for production deploys.

# Solana RPC endpoint (the app uses devnet by default). Recommend
# Helius over the default `api.devnet.solana.com` — Arcium callbacks
# are rate-dropped on the free public endpoint. Grab a Helius key at
# https://helius.dev (free tier works for browse + connect; Arcium
# interactions need the paid tier's higher throughput).
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Cluster name — UI surfaces this as a badge. One of:
#   devnet  |  mainnet-beta  |  testnet  |  localnet
NEXT_PUBLIC_CLUSTER=devnet

# Hermes (Pyth Pull Oracle) endpoint. Default public endpoint is fine
# for dev; point at a pinned mirror for prod SLAs.
NEXT_PUBLIC_HERMES_ENDPOINT=https://hermes.pyth.network/
